# ContextMarmot Environment Variables
#
# Copy this file to .env and fill in your values.
# API keys are never stored in vault config files.
#
# Usage: source .env before running marmot commands, or export directly:
#   export OPENAI_API_KEY=sk-...
#   marmot index --dir .marmot --force

# OpenAI API key (required when embedding_provider is "openai" in _config.md)
OPENAI_API_KEY=

# Voyage AI API key (future — not yet supported)
# VOYAGE_API_KEY=
