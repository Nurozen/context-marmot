+
+// TestWarrenNodeUpdateRefreshFailureWarns (A6 #4): a failed registry refresh
+// after an editable write is announced on stderr; the response is unaffected.
+func TestWarrenNodeUpdateRefreshFailureWarns(t *testing.T) {
