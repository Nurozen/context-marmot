+	}
+	// Registry wired but the vault was never loaded: Refresh errors.
+	wireWarrenVaultRegistry(t, engine)
+
+	updatePath := "/api/node/" + url.PathEscape("@project-a-vault/service/api")
+	var rec *httptest.ResponseRecorder
